{
  "name": "knowledge-transfer-agent",
  "version": "0.1.0",
  "description": "AI agent for capturing institutional knowledge from retiring employees",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "setup:search-index": "tsx src/storage/search-index-setup.ts",
    "setup:cosmos": "tsx src/storage/cosmos-nosql-client.ts --init"
  },
  "dependencies": {
    "@azure/ai-projects": "^1.0.0-beta.10",
    "@azure/cosmos": "^4.2.0",
    "@azure/identity": "^4.6.0",
    "@azure/openai": "^3.0.0-beta.1",
    "@azure/search-documents": "^12.1.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@microsoft/teams-ai": "^1.6.0",
    "adaptive-expressions": "^4.23.1",
    "applicationinsights": "^3.4.0",
    "botbuilder": "^4.23.1",
    "botframework-connector": "^4.23.1",
    "express": "^5.0.1",
    "gremlin": "^3.7.3",
    "isomorphic-fetch": "^3.0.0",
    "tiktoken": "^1.0.18",
    "uuid": "^11.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.0",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.20.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
