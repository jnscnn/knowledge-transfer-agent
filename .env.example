# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://kt-openai-{suffix}.openai.azure.com/
AZURE_OPENAI_API_KEY=

# Chat completion model — used for interviews, query answers, and complex reasoning.
# Change this to any Azure OpenAI chat deployment (e.g., gpt-4.1, o3-mini, gpt-4o-mini).
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o

# Auxiliary model — used for bulk tasks: entity extraction, sensitivity classification,
# domain classification. Can be a cheaper/faster model than the chat model.
# Defaults to AZURE_OPENAI_CHAT_DEPLOYMENT if not set.
AZURE_OPENAI_AUXILIARY_DEPLOYMENT=gpt-4o

# Embedding model — change deployment and dimensions together if swapping models.
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_EMBEDDING_DIMENSIONS=3072

# Azure AI Search
AZURE_SEARCH_ENDPOINT=https://kt-search-{suffix}.search.windows.net
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_INDEX=knowledge-chunks

# Cosmos DB — NoSQL API (documents & metadata)
COSMOS_NOSQL_ENDPOINT=https://kt-cosmos-nosql-{suffix}.documents.azure.com:443/
COSMOS_NOSQL_KEY=
COSMOS_NOSQL_DATABASE=kt-agent

# Cosmos DB — Gremlin API (knowledge graph) — SEPARATE account required
COSMOS_GREMLIN_ENDPOINT=wss://kt-cosmos-graph-{suffix}.gremlin.cosmos.azure.com:443/
COSMOS_GREMLIN_KEY=
COSMOS_GREMLIN_DATABASE=kt-graph

# Azure Functions
FUNCTION_APP_URL=https://kt-functions-{suffix}.azurewebsites.net

# Bot Service
BOT_ID=
BOT_PASSWORD=

# Microsoft Graph API
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_TENANT_ID=

# Key Vault
KEY_VAULT_URI=https://kt-kv-{suffix}.vault.azure.net/

# Application Insights
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Server
PORT=3978
